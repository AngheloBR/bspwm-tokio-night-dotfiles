# Colors Tokyo Night
set color_cmdline_bg       = default
set color_cmdline_fg       = c0caf5
set color_error            = f7768e
set color_info             = 7dcfff
set color_info_bg          = default
set color_info_fg          = 7dcfff
set color_linenr           = 565f89
set color_linenr_bg        = default
set color_linenr_fg        = 565f89
set color_msg              = 9ece6a
set color_msg_bg           = default
set color_msg_fg           = 9ece6a
set color_playlist_bg      = default
set color_playlist_fg      = c0caf5
set color_playlist_selected_bg = 7aa2f7
set color_playlist_selected_fg = 1a1b26
set color_playlist_cur_bg  = 2f3549
set color_playlist_cur_fg  = 7aa2f7
