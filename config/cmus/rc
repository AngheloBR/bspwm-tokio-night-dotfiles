# Opciones
set softvol=true
set vol_step=5
set repeat=false
set shuffle=false
set continue=true
set resume_status_line_format="%{state} %{artist} - %{title} [%{duration}]"
set status_display=1
set output_plugin=pipewire
set audio_backend=pipewire
