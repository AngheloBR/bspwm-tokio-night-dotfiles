#!/usr/bin/env bash

# ============================================================
# bspwmrc - Tokyo Night Edition
# ============================================================

# --- Cargar colores Tokyo Night ---
source "${BSPWM_CONFIG_DIR:-$HOME/.config/bspwm}/colors.sh" 2>/dev/null || \
  source "$HOME/.config/themes/colors-tokyo-night.sh" 2>/dev/null

# --- Configuración de bordes ---
bspc config border_width          2
bspc config window_gap            8
bspc config top_padding           32
bspc config left_padding          0
bspc config right_padding         0
bspc config bottom_padding        0
bspc config split_ratio           0.52

# --- Colores de bordes Tokyo Night ---
bspc config focused_border_color       "#7aa2f7"
bspc config active_border_color        "#3b4261"
bspc config normal_border_color        "#24283b"
bspc config presel_feedback_color      "#bb9af7"
bspc config urgent_border_color        "#f7768e"

# --- Comportamiento de monitores ---
bspc config borderless_monocle         true
bspc config gapless_monocle            true
bspc config single_monocle             false
bspc config focus_follows_pointer      false
bspc config pointer_follows_monitor    true
bspc config pointer_follows_focus      false
bspc config click_to_focus             true
bspc config focus_by_distance          true
bspc config history_aware_focus        false
bspc config remove_unplugged_monitors  true
bspc config merge_overlapping_monitors true
bspc config honor_size_hints           false

# --- Reglas de ventanas ---
bspc rule -a Gimp                   desktop='^8' state=floating follow=on
bspc rule -a Chromium               desktop='^2'
bspc rule -a firefox                desktop='^1'
bspc rule -a Alacritty              desktop='^3'
bspc rule -a "polybar-*"            state=floating
bspc rule -a Rofi                   state=floating layer=top
bspc rule -a Dunst                  state=floating layer=top
bspc rule -a Picom                  state=floating layer=top
bspc rule -a Nitrogen               state=floating
bspc rule -a feh                    state=floating
bspc rule -a "Viewnior|qview|eog"   state=floating
bspc rule -a "Pavucontrol"          state=floating follow=on
bspc rule -a "Galculator|Qalculate" state=floating
bspc rule -a "Lxappearance"         state=floating
bspc rule -a "Arandr"               state=floating
bspc rule -a "Xfce4-power-manager"  state=floating
bspc rule -a "Xfce4-settings-manager" state=floating

# --- Desktop setup ---
bspc monitor -d I II III IV V VI VII VIII IX X

# --- Compositor ---
pgrep -x picom >/dev/null || picom --config "$HOME/.config/picom/picom.conf" &

# --- Barra ---
pgrep -x polybar >/dev/null || "$HOME/.config/polybar/launch.sh" &

# --- Notificaciones ---
pgrep -x dunst >/dev/null || dunst -config "$HOME/.config/dunst/dunstrc" &

# --- Wallpaper (último wallpaper de pywal) ---
if [ -f "$HOME/.cache/wal/wal" ]; then
  feh --bg-fill "$(cat "$HOME/.cache/wal/wal")"
fi
